APP_NAME=Supply Chain AI Backend
ENVIRONMENT=docker
API_PREFIX=/api/v1

MYSQL_DATABASE=supply_chain
MYSQL_USER=supply_chain
MYSQL_PASSWORD=supply_chain
MYSQL_ROOT_PASSWORD=root
MYSQL_PORT=3306

REDIS_PORT=6379
BACKEND_PORT=8000
FRONTEND_PORT=80
AI_SERVICE_PORT=8081

RISK_THRESHOLD=0.85
ALLOWED_ORIGINS=http://localhost,http://localhost:5173,http://127.0.0.1:5173
REPLAY_RATE=1
TZ=Asia/Shanghai
